<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="Customs Portal - Full Cycle" verbose="1">

    <test name="Manifest Creation Flow">
        <groups>
            <run>
                <include name="authentication"/>
                <include name="manifest"/>
            </run>
        </groups>
        <classes>
            <class name="portal.Tests.LoginTest"/>
            <class name="portal.Tests.ManifestTest"/>
            <class name="portal.Tests.ValidateDuplicateManifestAPITest"/>
        </classes>
    </test>

</suite>
