<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="Create and submission manifest end to end scenario" verbose="1">

    <!--
        ترتيب التنفيذ المضمون:
        LoginTest (authentication)
            ↓
        ManifestTest (manifest)
            ↓
        fillBillOfLadingTC (fill-bl)
            ↓
        createBillOfLadingItemsTC (bill-of-lading-items)
            ↓
        saveBillOfLadingTC (save-bl)
            ↓
        verifyBillOfLadingAciDataTC (BillOfLadingFlow)
            ↓
        editManifestTC (edit-manifest)
            ↓
        submitManifestTC → assertManifestSubmissionDateIsNotNull (submit-manifest)
    -->
    <test name="Create and submission manifest end to end scenario">
        <groups>
            <run>
                <include name="authentication"/>
                <include name="manifest"/>
                <include name="fill-bl"/>
                <include name="bill-of-lading-items"/>
                <include name="save-bl"/>
                <include name="BillOfLadingFlow"/>
                <include name="edit-manifest"/>
                <include name="submit-manifest"/>
            </run>
        </groups>
        <classes>
            <class name="portal.Tests.LoginTest"/>
            <class name="portal.Tests.ManifestTest"/>
            <class name="portal.Tests.CreateBillOfLadingTest"/>
            <class name="portal.Tests.CreateBillOfLadingItemsTest"/>
            <class name="portal.Tests.EditManifestTest"/>
            <class name="portal.Tests.SubmissionManifestTest"/>
        </classes>
    </test>

</suite>
