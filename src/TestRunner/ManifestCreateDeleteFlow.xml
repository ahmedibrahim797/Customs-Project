<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd" >

<suite name="Manifest Create and Delete Flow" verbose="1">

    <!-- Login → Create Manifest → Delete Manifest from DB -->
    <test name="Manifest Create and Delete Flow">
        <groups>
            <run>
                <include name="authentication"/>
                <include name="manifest"/>
                <include name="manifest-delete"/>
            </run>
        </groups>
        <classes>
            <class name="portal.Tests.LoginTest"/>
            <class name="portal.Tests.ManifestTest"/>
            <class name="portal.Tests.DeleteManifestTest"/>
        </classes>
    </test>

</suite>
